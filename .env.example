# ═══════════════════════════════════════════════════════════════════════════
# Research Assistant Labs — environment variables
# Copy this file to `.env` and fill in the values. NEVER commit your real .env.
# All values are read by config.py; lab code never reads env vars directly.
# ═══════════════════════════════════════════════════════════════════════════

# ─── LLM PROVIDER ────────────────────────────────────────────────────────────
# Which chat/LLM provider config.py should build. Options: azure | openai | mock
#   azure  -> Azure OpenAI (default for this course)
#   openai -> vanilla OpenAI (set OPENAI_API_KEY / OPENAI_MODEL below)
#   mock   -> deterministic offline fake LLM (no network; great for smoke tests)
LLM_PROVIDER=azure

# ─── AZURE OPENAI (chat) ─────────────────────────────────────────────────────
# The endpoint may be pasted as the full ".../openai/v1/responses" URL — config.py
# normalizes it down to the resource base automatically.
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1/responses
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ─── OPENAI (only if LLM_PROVIDER=openai) ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── EMBEDDINGS PROVIDER ─────────────────────────────────────────────────────
# Options: fastembed | azure | openai | fake
#   fastembed -> local ONNX embeddings, no torch, no cloud (default). Downloads a
#                ~130MB model once, then fully offline. Best for this course.
#   azure     -> Azure OpenAI embeddings (requires an embeddings DEPLOYMENT below)
#   openai    -> OpenAI embeddings
#   fake      -> deterministic hash embeddings, zero downloads (CI / airplane mode)
EMBEDDINGS_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# Only needed if EMBEDDINGS_PROVIDER=azure (you must create this deployment):
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# ─── VECTOR STORE ────────────────────────────────────────────────────────────
CHROMA_DB_DIR=.chroma
CHROMA_COLLECTION=research_assistant

# ─── WEB SEARCH TOOL (Day 4) ─────────────────────────────────────────────────
# Options: mock (default, offline) | tavily
WEB_SEARCH_PROVIDER=mock
TAVILY_API_KEY=

# ─── OBSERVABILITY / LANGSMITH (Day 7) ───────────────────────────────────────
# Leave LANGSMITH_TRACING=false to run without tracing. Set true + add a key to
# stream traces to https://smith.langchain.com.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-assistant-labs
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── WEB UI PORTS ────────────────────────────────────────────────────────────
backend_port=5000
frontend_port=9000
